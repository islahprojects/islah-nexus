# Islah Nexus MVP environment example
# Copy this to .env and fill locally.
# Do not commit real secrets.

# Local API token
ISLAH_API_TOKEN=<set-local-token-here>

# Notion bridge
NOTION_TOKEN=PASTE_NOTION_INSTALLATION_ACCESS_TOKEN_HERE
NOTION_DATABASE_ID=5306c30a-839f-4aca-acb3-69a5e7d1d612

# Local API
ISLAH_API_HOST=127.0.0.1
ISLAH_API_PORT=8000

